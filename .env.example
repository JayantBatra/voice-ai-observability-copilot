# Copy to .env. Fixtures run with none of these set; live mode needs the GHL block.
PORT=3000

# --- LLM (recommendation layer). Without a key, recommendations are rule-based. ---
LLM_API_KEY=
LLM_PROVIDER=openai            # openai | anthropic
LLM_MODEL=gpt-4o-mini

# --- HighLevel OAuth (required for live mode) ---
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REDIRECT_URI=https://<your-host>/oauth/callback
GHL_API_BASE=https://services.leadconnectorhq.com

# --- Behavior toggles ---
# SEED_FIXTURES=false         # force live-only even before install (default: fixtures until installed)
# VERIFY_WEBHOOKS=false       # disable webhook signature check for local curl testing (default: ON)

# --- Optional: override GHL webhook public keys if they ever rotate ---
# GHL_ED25519_PUBLIC_KEY=
# GHL_RSA_PUBLIC_KEY=
